{
  "name": "comfy-prompt-generator",
  "version": "0.1.0",
  "description": "Interactive CLI for generating structured image prompts for ComfyUI",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/index.js",
  "bin": {
    "comfy-prompt": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "comfyui",
    "prompt",
    "generator",
    "cli",
    "flux"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
